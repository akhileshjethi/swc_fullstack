            "body": {
              "mode": "raw",
              "raw": "{\n  \"theatreName\": \"PVR Cinemas - Forum Mall\",\n  \"address\": \"Forum Mall, MG Road\",\n  \"locationId\": \"LOC001\",\n  \"ownerId\": \"OWNER001\"\n}"
            },
            "url": "{{catalog_base_url}}/theatres"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Theatre created', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('theatre_id', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Get Theatre by ID (CACHE MISS then HIT)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/theatres/{{theatre_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Theatre retrieved', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Booking Service - Show Caching",
      "item": [
        {
          "name": "3.1 Create Show (evicts 'shows' cache)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": \"{{movie_id}}\",\n  \"theatreId\": \"{{theatre_id}}\",\n  \"auditoriumId\": \"AUD001\",\n  \"startTime\": \"2026-12-25T18:00:00\",\n  \"endTime\": \"2026-12-25T20:30:00\",\n  \"language\": \"English\"\n}"
            },
            "url": "{{booking_base_url}}/shows"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Show created', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('show_id', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Get Show by ID (CACHE MISS)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/shows/{{show_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Show retrieved - CACHE MISS', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 Get Show by ID (CACHE HIT)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/shows/{{show_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Show retrieved - CACHE HIT', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Booking Service - Seat Availability Caching",
      "item": [
        {
          "name": "4.1 Get Show Seats (CACHE MISS - first call)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/shows/{{show_id}}/seats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seat availability retrieved - CACHE MISS', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.environment.set('seat_first_time', pm.response.responseTime);",
                  "    console.log('Seat API first call (DB): ' + pm.response.responseTime + 'ms');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Get Show Seats (CACHE HIT - second call)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/shows/{{show_id}}/seats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seat availability - CACHE HIT', function() {",
                  "    pm.response.to.have.status(200);",
                  "    console.log('Seat API cached call: ' + pm.response.responseTime + 'ms');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.3 Lock Seats (evicts seatAvailability cache)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"showId\": {{show_id}},\n  \"seatNumbers\": [\"A1\", \"A2\"]\n}"
            },
            "url": "{{booking_base_url}}/bookings/lock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seats locked - cache evicted', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.4 Get Show Seats (CACHE MISS - after lock)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/shows/{{show_id}}/seats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seat availability after lock - CACHE MISS', function() {",
                  "    pm.response.to.have.status(200);",
                  "    console.log('Seats now show LOCKED status for A1, A2');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.5 Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"showId\": {{show_id}},\n  \"seatNumbers\": [\"A1\", \"A2\"]\n}"
            },
            "url": "{{booking_base_url}}/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Booking created in INITIATED state', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('booking_id', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.6 Confirm Booking (evicts seatAvailability cache)",
          "request": {
            "method": "PUT",
            "url": "{{booking_base_url}}/bookings/{{booking_id}}/confirm"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Booking confirmed - seatAvailability cache evicted', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.status).to.eql('CONFIRMED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.7 Get Show Seats (CACHE MISS - after confirm)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/shows/{{show_id}}/seats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seat availability after confirm - CACHE MISS', function() {",
                  "    pm.response.to.have.status(200);",
                  "    console.log('Seats A1, A2 should now show BOOKED status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Actuator & Monitoring",
      "item": [
        {
          "name": "5.1 Catalog - Health Check (includes Redis)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/actuator/health"
          },
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health check returns UP with Redis status', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "5.2 Catalog - Cache Statistics",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/actuator/caches"
          },
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cache endpoint returns registered caches', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.cacheManagers).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "5.3 Booking - Health Check (includes Redis)",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/actuator/health"
          },
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health check returns UP', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "5.4 Booking - Cache Statistics",
          "request": {
            "method": "GET",
            "url": "{{booking_base_url}}/actuator/caches"
          },
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cache endpoint returns registered caches', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "5.5 Catalog - Cache Metrics (Hits/Misses)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/actuator/metrics/cache.gets?tag=result:hit"
          },
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cache hit metrics available', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
