{
  "info": {
    "name": "CineVerse Redis Cache Tests",
    "description": "Postman collection for testing Redis caching integration in CineVerse microservices. Tests cache HIT/MISS behavior, eviction strategies, TTL expiry, and performance comparison.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "catalog_base_url",
      "value": "http://localhost:8082"
    },
    {
      "key": "booking_base_url",
      "value": "http://localhost:8083"
    },
    {
      "key": "jwt_token",
      "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0X2FkbWluIiwicm9sZXMiOlsiUk9MRV9BRE1JTiJdLCJpYXQiOjE5MDAwMDAwMDAsImV4cCI6MjAwMDAwMDAwMH0.placeholder"
    },
    {
      "key": "movie_id",
      "value": ""
    },
    {
      "key": "theatre_id",
      "value": ""
    },
    {
      "key": "show_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Catalog Service - Movie Caching",
      "item": [
        {
          "name": "1.1 Create Movie (evicts 'movies' cache)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception\",\n  \"genre\": \"Sci-Fi\",\n  \"language\": \"English\",\n  \"duration\": 148,\n  \"rating\": 8.8,\n  \"releaseDate\": \"2010-07-16\",\n  \"description\": \"A thief who steals corporate secrets through dream-sharing technology.\",\n  \"posterUrl\": \"https://example.com/inception.jpg\"\n}"
            },
            "url": "{{catalog_base_url}}/movies"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movie created successfully', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('movie_id', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Get Movie by ID (1st call - CACHE MISS)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/movies/{{movie_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movie retrieved - CACHE MISS (check server logs)', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.environment.set('first_request_time', pm.response.responseTime);",
                  "    console.log('First request time (DB): ' + pm.response.responseTime + 'ms');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Get Movie by ID (2nd call - CACHE HIT)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/movies/{{movie_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movie retrieved - CACHE HIT (no DB log expected)', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var firstTime = parseInt(pm.environment.get('first_request_time'));",
                  "    console.log('Second request time (Cache): ' + pm.response.responseTime + 'ms');",
                  "    console.log('First request time (DB): ' + firstTime + 'ms');",
                  "    console.log('Performance improvement: ' + (firstTime - pm.response.responseTime) + 'ms faster');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Get All Movies (1st call - CACHE MISS)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/movies?page=0&size=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movies list retrieved', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.5 Update Movie (evicts 'movie' + 'movies' cache)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception - Director's Cut\",\n  \"genre\": \"Sci-Fi\",\n  \"language\": \"English\",\n  \"duration\": 162,\n  \"rating\": 9.0,\n  \"releaseDate\": \"2010-07-16\",\n  \"description\": \"Extended director's cut with additional scenes.\",\n  \"posterUrl\": \"https://example.com/inception-dc.jpg\"\n}"
            },
            "url": "{{catalog_base_url}}/movies/{{movie_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movie updated - cache evicted', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.6 Get Movie by ID (after update - CACHE MISS again)",
          "request": {
            "method": "GET",
            "url": "{{catalog_base_url}}/movies/{{movie_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movie retrieved after update - CACHE MISS', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.title).to.eql('Inception - Director\\'s Cut');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.7 Delete Movie (evicts 'movie' + 'movies' cache)",
          "request": {
            "method": "DELETE",
            "url": "{{catalog_base_url}}/movies/{{movie_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movie deleted - cache evicted', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Catalog Service - Theatre Caching",
      "item": [
        {
          "name": "2.1 Create Theatre (evicts 'theatres' cache)",
          "request": {
            "method": "POST",
